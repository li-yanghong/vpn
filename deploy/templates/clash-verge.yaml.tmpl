mixed-port: ${LOCAL_MIXED_PORT}
allow-lan: false
mode: rule
log-level: info
ipv6: true
unified-delay: true

proxies:
  - name: ${CLIENT_NAME}
    type: vless
    server: ${SERVER_HOST}
    port: ${SERVER_PORT}
    uuid: ${UUID}
    network: tcp
    udp: true
    packet-encoding: xudp
    encryption: ""
    tls: true
    flow: xtls-rprx-vision
    servername: ${REALITY_SERVER_NAME}
    client-fingerprint: chrome
    skip-cert-verify: false
    reality-opts:
      public-key: ${REALITY_PUBLIC_KEY}
      short-id: ${REALITY_SHORT_ID}

proxy-groups:
  - name: PROXY
    type: select
    proxies:
      - ${CLIENT_NAME}
      - DIRECT

rule-providers:
  private:
    type: http
    behavior: ipcidr
    path: ./ruleset/private_ip.yaml
    url: https://raw.githubusercontent.com/MetaCubeX/meta-rules-dat/meta/geo/geoip/private.yaml
    interval: 86400
  cn:
    type: http
    behavior: domain
    path: ./ruleset/cn_domain.yaml
    url: https://raw.githubusercontent.com/MetaCubeX/meta-rules-dat/meta/geo/geosite/cn.yaml
    interval: 86400
  ai:
    type: http
    behavior: domain
    path: ./ruleset/ai_domain.yaml
    url: https://raw.githubusercontent.com/MetaCubeX/meta-rules-dat/meta/geo/geosite/category-ai-!cn.yaml
    interval: 86400
  openai:
    type: http
    behavior: domain
    path: ./ruleset/openai_domain.yaml
    url: https://raw.githubusercontent.com/MetaCubeX/meta-rules-dat/meta/geo/geosite/openai.yaml
    interval: 86400
  google:
    type: http
    behavior: domain
    path: ./ruleset/google_domain.yaml
    url: https://raw.githubusercontent.com/MetaCubeX/meta-rules-dat/meta/geo/geosite/google.yaml
    interval: 86400
  github:
    type: http
    behavior: domain
    path: ./ruleset/github_domain.yaml
    url: https://raw.githubusercontent.com/MetaCubeX/meta-rules-dat/meta/geo/geosite/github.yaml
    interval: 86400
  telegram:
    type: http
    behavior: domain
    path: ./ruleset/telegram_domain.yaml
    url: https://raw.githubusercontent.com/MetaCubeX/meta-rules-dat/meta/geo/geosite/telegram.yaml
    interval: 86400
  telegram_ip:
    type: http
    behavior: ipcidr
    path: ./ruleset/telegram_ip.yaml
    url: https://raw.githubusercontent.com/MetaCubeX/meta-rules-dat/meta/geo/geoip/telegram.yaml
    interval: 86400
  tiktok:
    type: http
    behavior: domain
    path: ./ruleset/tiktok_domain.yaml
    url: https://raw.githubusercontent.com/MetaCubeX/meta-rules-dat/meta/geo/geosite/tiktok.yaml
    interval: 86400
  twitter:
    type: http
    behavior: domain
    path: ./ruleset/twitter_domain.yaml
    url: https://raw.githubusercontent.com/MetaCubeX/meta-rules-dat/meta/geo/geosite/twitter.yaml
    interval: 86400
  netflix:
    type: http
    behavior: domain
    path: ./ruleset/netflix_domain.yaml
    url: https://raw.githubusercontent.com/MetaCubeX/meta-rules-dat/meta/geo/geosite/netflix.yaml
    interval: 86400
  youtube:
    type: http
    behavior: domain
    path: ./ruleset/youtube_domain.yaml
    url: https://raw.githubusercontent.com/MetaCubeX/meta-rules-dat/meta/geo/geosite/youtube.yaml
    interval: 86400
  proxymedia:
    type: http
    behavior: domain
    path: ./ruleset/proxymedia_domain.yaml
    url: https://raw.githubusercontent.com/MetaCubeX/meta-rules-dat/meta/geo/geosite/proxymedia.yaml
    interval: 86400
  proxy:
    type: http
    behavior: domain
    path: ./ruleset/proxy_domain.yaml
    url: https://raw.githubusercontent.com/MetaCubeX/meta-rules-dat/meta/geo/geosite/proxy.yaml
    interval: 86400

rules:
  - RULE-SET,private,DIRECT,no-resolve
  - RULE-SET,cn,DIRECT
  - RULE-SET,ai,PROXY
  - RULE-SET,openai,PROXY
  - RULE-SET,google,PROXY
  - RULE-SET,github,PROXY
  - RULE-SET,telegram,PROXY
  - RULE-SET,telegram_ip,PROXY,no-resolve
  - RULE-SET,tiktok,PROXY
  - RULE-SET,twitter,PROXY
  - RULE-SET,netflix,PROXY
  - RULE-SET,youtube,PROXY
  - RULE-SET,proxymedia,PROXY
  - RULE-SET,proxy,PROXY
  - MATCH,DIRECT
